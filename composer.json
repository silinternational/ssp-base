{
  "name": "silinternational/ssp-base",
  "description": "Base image for SimpleSAMLphp",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Phillip Shipley",
      "email": "phillip.shipley@gmail.com"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=7.4",
    "ext-gmp": "*",
    "ext-memcached": "*",
    "simplesamlphp/simplesamlphp": "~1.19.1",
    "simplesamlphp/composer-module-installer": "1.1.8",
    "silinternational/simplesamlphp-module-expirychecker": "dev-feature/ssp-1-19",
    "silinternational/simplesamlphp-module-silauth": "dev-feature/ssp-1-19",
    "silinternational/simplesamlphp-module-mfa": "dev-feature/update-deps",
    "silinternational/simplesamlphp-module-profilereview": "dev-feature/ssp-1-19",
    "silinternational/ssp-utilities": "^1.0.6",
    "silinternational/simplesamlphp-module-material": "dev-feature/ssp-1-19",
    "silinternational/simplesamlphp-module-sildisco": "dev-feature/ssp-1-19",
    "silinternational/php-env": "^2.1.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5.19",
    "roave/security-advisories": "dev-master"
  },
  "autoload": {
    "files": [
      "vendor/yiisoft/yii2/Yii.php"
    ]
  }
}
